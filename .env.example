# Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_DATABASE=inventory_db

# Note: DB_PORT should be 5433 for local dev if mapping to host as per docker-compose
# When running via docker-compose up app, it will connect to 'db' using DB_HOST=db

# Postgres Docker Initialization
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=inventory_db
